// NearSupply RFQ/Quotation Management Platform
// Prisma Schema - Database Design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  SUPPLIER
  CLIENT
}

enum RFQStatus {
  DRAFT
  SUBMITTED
  ASSIGNED
  QUOTES_RECEIVED
  UNDER_REVIEW
  COMPLETED
  CANCELLED
}

enum RFQRequestType {
  PRODUCT
  SERVICE
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

// ==================== USER ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(CLIENT)
  company   String?
  phone     String?
  avatar    String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  siteSettings  SiteSettings?  @relation("SiteSettingsUser")
  uploadedFiles UploadedFile[] @relation("UploadedFileUser")
  products      Product[]      @relation("ProductSupplier")
  rfqRequests   RFQRequest[]   @relation("RFQRequestClient")
  proposals     Proposal[]     @relation("ProposalSupplier")
  notifications Notification[] @relation("NotificationUser")

  @@index([email])
  @@index([role])
  @@map("users")
}

// ==================== SITE SETTINGS ====================

model SiteSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  siteName           String?
  siteLogo           String?
  primaryColor       String?
  timezone           String?
  currency           String?
  language           String?
  emailNotifications Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user User @relation("SiteSettingsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("site_settings")
}

// ==================== UPLOADED FILE ====================

model UploadedFile {
  id           String   @id @default(cuid())
  userId       String
  originalName String
  fileName     String
  filePath     String
  fileSize     Int
  mimeType     String
  entity       String? // Related entity type (RFQRequest, Proposal, etc.)
  entityId     String? // Related entity ID
  createdAt    DateTime @default(now())

  // Relations
  user User @relation("UploadedFileUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@map("uploaded_files")
}

// ==================== PRODUCT ====================

model Product {
  id                   String        @id @default(cuid())
  supplierId           String
  name                 String
  description          String?
  category             String?
  sku                  String?
  unitPrice            Float
  currency             String        @default("USD")
  minimumOrderQuantity Float?
  unit                 String?
  isFeatured           Boolean       @default(false)
  status               ProductStatus @default(ACTIVE)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  supplier User @relation("ProductSupplier", fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([category])
  @@index([status])
  @@map("products")
}

// ==================== RFQ REQUEST ====================

model RFQRequest {
  id              String         @id @default(cuid())
  requestNumber   String         @unique
  requestType     RFQRequestType @default(PRODUCT)
  title           String
  description     String?
  category        String?
  budget          Float?
  currency        String         @default("USD")
  submissionDate  DateTime?
  deadlineDate    DateTime?
  deliveryDate    DateTime?
  deliveryTerms   String?
  deliveryAddress String?
  notes           String?
  internalNotes   String?
  status          RFQStatus      @default(DRAFT)
  clientId        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  client    User       @relation("RFQRequestClient", fields: [clientId], references: [id])
  lineItems RFQItem[]
  proposals Proposal[]

  @@index([clientId])
  @@index([status])
  @@index([requestNumber])
  @@map("rfq_requests")
}

// ==================== RFQ ITEM ====================

model RFQItem {
  id             String   @id @default(cuid())
  rfqRequestId   String
  name           String
  quantity       Float
  unit           String?
  specifications String?
  link           String?
  imageUrl       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  rfqRequest RFQRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)

  @@index([rfqRequestId])
  @@map("rfq_items")
}

// ==================== PROPOSAL ====================

model Proposal {
  id              String         @id @default(cuid())
  proposalNumber  String         @unique
  rfqRequestId    String
  supplierId      String
  lineItems       String? // JSON array of line items with pricing
  subtotal        Float          @default(0)
  currency        String         @default("USD")
  attachments     String? // JSON array of file paths
  notes           String?
  deliveryTerms   String?
  validity        Int? // Validity period in days
  status          ProposalStatus @default(DRAFT)
  adminMargin     Float          @default(0)
  shippingCost    Float          @default(0)
  taxPercentage   Float          @default(0)
  taxAmount       Float          @default(0)
  grandTotal      Float          @default(0)
  termsConditions String?
  emailSentAt     DateTime?
  emailSentTo     String? // JSON array of email addresses
  isShared        Boolean        @default(false)
  sharedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  rfqRequest RFQRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  supplier   User       @relation("ProposalSupplier", fields: [supplierId], references: [id])

  @@index([rfqRequestId])
  @@index([supplierId])
  @@index([status])
  @@index([proposalNumber])
  @@map("proposals")
}

// ==================== NOTIFICATION ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
